# ============================================
# 生产环境变量配置示例
# 复制此文件为 .env.production 并修改为真实值
# ============================================

# 数据库配置
DB_URL=jdbc:mysql://mysql:3306/demo?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=demo
DB_PASSWORD=your-strong-db-password-here

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password-here
REDIS_DATABASE=0

# Kafka 配置
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# JWT 配置 (生产环境必须使用强随机密钥，至少 256 位)
JWT_SECRET=your-strong-random-secret-key-at-least-256-bits-for-production-security
JWT_EXPIRATION=3600000

# CORS 允许的域名 (生产环境必须指定具体域名)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com

# 服务器端口
SERVER_PORT=8080